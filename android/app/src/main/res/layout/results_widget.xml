<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical"
    android:padding="@dimen/widget_padding">

    <!-- Header: Lottery Name and Draw Type -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingBottom="@dimen/widget_inner_padding"
        android:background="@color/primary_purple"
        android:gravity="center">

        <TextView
            android:id="@+id/widget_lottery_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lottery_name"
            android:textColor="@color/white"
            android:textSize="@dimen/widget_text_size_title"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_lottery_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lottery_description"
            android:textColor="@color/white"
            android:textSize="@dimen/widget_text_size_subtitle"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Winning Numbers Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:paddingVertical="@dimen/widget_inner_padding"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today\'s Numbers"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/widget_text_size_subtitle"
            android:layout_marginBottom="@dimen/widget_inner_padding" />

        <TextView
            android:id="@+id/widget_lottery_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lottery_result"
            android:textColor="@color/text_dark"
            android:textSize="@dimen/widget_text_size_numbers"
            android:textStyle="bold"
            android:letterSpacing="0.05" />


    </LinearLayout>

    <!-- Footer: Next Draw Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="@dimen/widget_inner_padding"
        android:background="@color/primary_light"
        android:gravity="center">

        <TextView
            android:id="@+id/widget_next_draw"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/next_draw"
            android:textColor="@color/primary_purple"
            android:textSize="@dimen/widget_text_size_subtitle"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tap_to_view"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</LinearLayout>
